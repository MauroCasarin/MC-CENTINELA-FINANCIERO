{
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/analyze",
      "destination": "/api/index.ts"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!assets/|favicon.ico|api/).*)",
      "destination": "/index.html"
    }
  ]
}
